# Backend Environment Configuration
# Copy this to backend/.env and fill in your values

# Environment
ENV=development  # or production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Reddit API Credentials (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_REDIRECT_URI=http://localhost:5173/auth/callback
REDDIT_USER_AGENT=MoodMirror/1.0 (Development)

# Database - MariaDB (external)
# Database credentials (you'll set these up separately)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME_DEV=moodmirror_dev
DB_NAME_PROD=moodmirror

# Redis Configuration (using docker-compose.dev.yml with password)
REDIS_URL=redis://:your_redis_password@localhost:6379/0
REDIS_PASSWORD=your_redis_password

# Security Keys (CHANGE THESE IN PRODUCTION!)
# Generate JWT secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1

# Generate encryption key: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=dev_encryption_key_exactly_32_bytes_long_hex

# Email Service (optional for development)
RESEND_API_KEY=re_your_resend_api_key_optional

# Model Path (relative to backend directory)
MODEL_PATH=../model/moodmirror_model.pt

# Rate Limiting
RATE_LIMIT_PER_DAY=100
RATE_LIMIT_ANALYZE_PER_DAY=10
RATE_LIMIT_AUTH_PER_HOUR=20

# CORS - Allow frontend origin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Debug Mode
DEBUG=true
RELOAD=true

# Frontend Configuration (Backend serves these to frontend)
FRONTEND_APP_NAME=MoodMirror
FRONTEND_APP_VERSION=1.0.0
FRONTEND_ENABLE_EMAIL_REPORT=true
FRONTEND_ENABLE_ANALYTICS=false
